;Version 2.04
;Revision 1/5/2026

; --------------------
; - Consts
; --------------------

modex_count = 6		;horizontal modes
modey_count = 6		;vertical modes
modec_count = 4		;color modes
color_count = 16	;color numbers

; --------------------
; - Variables
; --------------------

plotmode = COLSEL	;[$83] plot mode
			;	bits	7	0 = set pixel, 1 = clear pixel
			;	 "	6	0 = normal mode, 1 = XOR mode
			;	 "	5..0	not used
vdcram	= FREKAB0	;[$0ab0] detected VDC RAM (0 = 16k, 1 = 64k)
targscn	= FREKABA	;[$0aba] target screen
			;	bits	7	all graphics commands (0 = VIC-II, 1 = VDC)
			;	 "	6	CHAR command (0 = standard BASIC, 1 = VDC bitmap)
			;	 "	5..0	not used
autofast = FREKABA+1	;[$0abb] AUTOFAST mode
			;	bits	7	0 = disabled, 1 = enabled
			;	 "	6..0	not used
attrsrc	= FREKABA+2	;[$0abc] attribute source
			;	bits	7..4	background color (hi-nibble)
			;	 "	3..0	foreground color (lo-nibble)
modex	= FREKABA+3	;[$0abd] horizontal mode (0..5)
modey	= FREKABA+4	;[$0abe] vertical mode (0..5)
modec	= FREKABA+5	;[$0abf] color mode (0..3)

; --------------------
; - Jump table
; --------------------

JTBase	= FREK13		;[$1300] base address

StartWedge	= JTBase+$00	;Enable Wedge80
QuitWedge	= JTBase+$03	;Disable Wedge80
SetMem80	= JTBase+$06	;Set VDC bitmap address (GRAPNT -> VDC R18/R19)
GetMode80	= JTBase+$09	;Get VDC screen mode (VDC R25 bit 7 -> a)
SetTxt80	= JTBase+$0c	;Activate VDC text mode
SetBmp80	= JTBase+$0f	;Activate VDC bitmap mode
ClrBmp80	= JTBase+$12	;Clear VDC bitmap screen and reset coords
GetBgCol80	= JTBase+$15	;Get VDC mono background and border color (RGBI -> a)
SetBgCol80	= JTBase+$18	;Set VDC mono background and border color (a -> RGBI)
GetFgCol80	= JTBase+$1b	;Get VDC mono foreground color (RGBI -> a)
SetFgCol80	= JTBase+$1e	;Set VDC mono foreground color (a -> RGBI)
GPlot80		= JTBase+$21	;Draw a pixel (plotmode, XPOS, YPOS) (considering WIDTH and FILFLG)
ReadPt80	= JTBase+$24	;Test a pixel (plotmode, XPOS, YPOS)
				;(cell mask -> a, pixel status -> zero bit, out of range -> carry)
DrawLn80	= JTBase+$27	;Draw a line (plotmode, XPOS, YPOS, XDEST, YDEST)
Box80		= JTBase+$2a	;Draw a box (plotmode, XCORDl, YCORDl, XCORD2, YCORD2, BOXANG, x = fill flag)
Circle80	= JTBase+$2d	;Draw a circle (plotmode, XCIRCL, YCIRCL, XRCOS, YRCOS, YRSIN, XRSIN, ANGBEG, ANGEND)
				;(CIRSUB and DSTPOS to get 1st point on circle) (x = degrees per segment)
Paint80		= JTBase+$30	;Fill a graphics area (plotmode, XPOS, YPOS)
Char80		= JTBase+$33	;Print a BASIC string to VDC bitmap screen (Note: string must be in RAM#1)
				;(plotmode, a = length, x/y = address, COLCNT/ROWCNT = position, CHRREV = reverse)
